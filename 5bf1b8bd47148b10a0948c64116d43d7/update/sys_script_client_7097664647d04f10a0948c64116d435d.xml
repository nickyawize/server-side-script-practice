        <global>true</global>
        <isolate_script>true</isolate_script>
        <messages>custom_config_item_count</messages>
        <name>STRY0012718 - Alert on CI count</name>
        <order/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {
   if (isLoading || newValue === '') {
      return;
   }

	// Initialize GlideAjax
    const ga = new GlideAjax('global.ConfigurationItemFetcher');
    ga.addParam('sysparm_name', 'getConfigItemsCount');
    ga.addParam('sysparm_config_item_id', newValue);
    
    // Send request
    ga.getXMLAnswer(function(count) {

        if (count) 
			getMessage('custom_config_item_count', function(msg) {
				g_form.addInfoMessage(msg.replace('{0}', count));
			});
    });
   
}]]></script>
