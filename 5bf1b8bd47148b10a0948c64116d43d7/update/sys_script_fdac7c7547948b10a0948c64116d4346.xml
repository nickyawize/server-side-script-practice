        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    const shortDescFieldName = 'short_description';
    const incidentIds = [];
    const shortDescValue = current.getValue(shortDescFieldName);

    let incidentGR = new GlideRecord('incident');
    incidentGR.addActiveQuery();
    incidentGR.addQuery(shortDescFieldName, shortDescValue);
    incidentGR.addQuery('sys_id', '!=', current.getUniqueValue());
    incidentGR.query();

    while (incidentGR.next()) {
        incidentIds.push(incidentGR.getValue('number'));
    }

    if (incidentIds.length) {
        const newLine = '<br> • ';
        let message = gs.getMessage(
            'custom_found_duplicate_incidents',
            [
                incidentIds.length + '',
                shortDescValue,
                current.getElement('short_description').getLabel()
            ]
        );
        message += ` : ${newLine} ` + incidentIds.join(newLine);

        gs.addErrorMessage(message);
    }

})(current, previous);]]></script>
