        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	const appConstants = new global.AppConstants();
	// If Confidential value not changed or user does not have the role, stop the check
	const isCheckNotNeeded = current[appConstants.FieldConfidential] === current[appConstants.FieldConfidential] || gs.getUser().hasRole( appConstants.RoleSecurityOfficer );

	if(isCheckNotNeeded)
		return;
	
	const isConfidential = current.getValue(appConstants.FieldConfidential);
	const isAssignedToNull = current[appConstants.FieldAssignedTo]?.nil();

	if(isConfidential && isAssignedToNull) {
		gs.addErrorMessage(gs.getMessage('custom_prevent_confidential_without_assigned_to'));
		current.setAbortAction(true);
	}

})(current, previous);]]></script>
